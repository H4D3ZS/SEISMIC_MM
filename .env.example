# ─────────────────────────────────────────────────────────────────────────────
# CISV Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real tokens.
# ─────────────────────────────────────────────────────────────────────────────

# ── MAPBOX SATELLITE TOKEN ────────────────────────────────────────────────────
# REQUIRED for the Mapbox Satellite Streets map style (the default style).
# Get a free public token at https://account.mapbox.com/
# 
# Without this token, the app will fallback to CartoDB Dark Matter base map.
# Other tile styles (OpenFreeMap, Stadia, CartoDB) work with NO token required.
# ─────────────────────────────────────────────────────────────────────────────
VITE_MAPBOX_TOKEN=pk.eyJ1IjoiWU9VUl9VU0VSTkFNRSIsImEiOiJZT1VSX0tFWSJ9.EXAMPLE
